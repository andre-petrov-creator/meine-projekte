# Akquise-Pipeline (First Look) — Beispiel-Konfiguration
# Echte Werte in .env eintragen (.env ist via .gitignore ausgeschlossen)

# --- Gmail IMAP (Empfang) ---
GMAIL_USER=deine-akquise@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
GMAIL_IMAP_HOST=imap.gmail.com
GMAIL_IMAP_PORT=993

# --- Filter ---
# Nur Mails von dieser Absender-Adresse werden verarbeitet
FILTER_FROM_ADDRESS=andre-petrov@web.de

# --- Ablage-Pfade ---
# Basis-Verzeichnis für Objekt-Ordner
BASE_FOLDER=C:\Users\andre\OneDrive - APPV Personalvermittlung\Immobilien\001_AQUISE\Objekte

# --- Anthropic API (Fallback bei Adress-Extraktion) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# --- Logging ---
LOG_LEVEL=INFO

# --- Optional: SMTP (für spätere Reports) ---
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
